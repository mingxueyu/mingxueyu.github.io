---
import { readdirSync } from "node:fs";
import { join } from "node:path";

const audioDir = join(process.cwd(), "public", "audio");
let playlist: { url: string; name: string }[] = [];
try {
  playlist = readdirSync(audioDir)
    .filter((f) => /\.(mp3|ogg|wav|m4a|flac)$/i.test(f))
    .map((f) => ({
      url: `/audio/${encodeURIComponent(f)}`,
      name: f.replace(/\.[^.]+$/, ""),
    }));
} catch {}

const hasAudio = playlist.length > 0;
---

{hasAudio && (
  <script is:inline define:vars={{ playlist }}>
    (function() {
      if (!playlist || !playlist.length) return;

        var STORE_KEY = 'bg-player-state';
        var SAVE_THROTTLE = 800; // 最多每 800ms 写一次 localStorage

        var audio = new Audio();
        audio.loop = false;
        audio.volume = 0.5;
        audio.preload = 'auto';

        // ---- 从 localStorage 恢复状态 ----
        var state = { index: 0, time: 0, playing: true, volume: 0.5 };
        try {
          var saved = JSON.parse(localStorage.getItem(STORE_KEY));
          if (saved) {
            state.index = saved.index % playlist.length;
            state.time = saved.time || 0;
            state.playing = saved.playing !== false;
            state.volume = saved.volume != null ? saved.volume : 0.5;
          }
        } catch(e) {}

        var currentIndex = state.index;
        audio.volume = state.volume;

        // ---- 节流写入 localStorage ----
        var lastSave = 0;
        var saveTimer = 0;
        function saveState() {
          var now = Date.now();
          if (now - lastSave < SAVE_THROTTLE) {
            if (!saveTimer) {
              saveTimer = setTimeout(function() {
                saveTimer = 0;
                saveState();
              }, SAVE_THROTTLE - (now - lastSave) + 50);
            }
            return;
          }
          lastSave = Date.now();
          try {
            localStorage.setItem(STORE_KEY, JSON.stringify({
              index: currentIndex,
              time: audio.currentTime || 0,
              playing: !audio.paused,
              volume: state.volume
            }));
          } catch(e) {}
        }

        // ---- 建造 DOM ----
        var btn = document.createElement('div');
        btn.id = 'bg-player-btn';
        btn.title = '背景音乐';
        btn.innerHTML = '🎵';

        var popup = document.createElement('div');
        popup.id = 'bg-player-popup';
        popup.innerHTML =
          '<div class="pp-title"></div>' +
          '<div class="pp-controls">' +
          '<button id="pp-prev">⏮</button>' +
          '<button id="pp-play">▶</button>' +
          '<button id="pp-next">⏭</button>' +
          '</div>' +
          '<input type="range" class="pp-progress" id="pp-progress" min="0" max="100" value="0"/>' +
          '<div class="pp-vol">🔊 <input type="range" id="pp-vol" min="0" max="100" value="50"/></div>';

        document.body.appendChild(btn);
        document.body.appendChild(popup);

        var titleEl = popup.querySelector('.pp-title');
        var playBtn = popup.querySelector('#pp-play');
        var progressEl = popup.querySelector('#pp-progress');
        var volInput = popup.querySelector('#pp-vol');
        volInput.value = audio.volume * 100;

        function setUI(playing) {
          if (playing) {
            btn.classList.add('playing');
            playBtn.textContent = '⏸';
          } else {
            btn.classList.remove('playing');
            playBtn.textContent = '▶';
          }
        }

        // ---- 加载音轨（等 metadata 就绪后再 seek） ----
        var pendingSeek = 0;

        function loadTrack(index, seekTime) {
          currentIndex = index;
          var t = playlist[index];
          audio.src = t.url;
          titleEl.textContent = t.name;
          pendingSeek = seekTime || 0;
          progressEl.value = 0;
          // audio.src 赋值已触发加载，无需再调 load()
        }

        // metadata 加载完成后 seek 到目标位置
        audio.addEventListener('loadedmetadata', function() {
          if (pendingSeek > 0 && audio.duration && isFinite(audio.duration)) {
            audio.currentTime = Math.min(pendingSeek, audio.duration - 0.1);
          }
          pendingSeek = 0;
        });

        // ---- 自动播放 & 浏览器策略应对 ----
        var isMuted = false;  // 因浏览器策略被迫静音

        function updateMuteUI() {
          if (isMuted) {
            btn.innerHTML = '🔇';
            btn.title = '背景音乐（已静音，点击页面任意位置开启声音）';
          } else {
            btn.innerHTML = '🎵';
            btn.title = '背景音乐';
          }
        }

        // 尝试恢复音量（由用户交互触发）
        var unmutePending = false;
        function tryUnmute() {
          if (!isMuted || !unmutePending) return;
          unmutePending = false;
          // 恢复保存的音量
          audio.muted = false;
          audio.volume = state.volume;
          volInput.value = audio.volume * 100;
          isMuted = false;
          updateMuteUI();
          saveState();
        }

        function tryPlay() {
          var p = audio.play();
          if (p && p.then) {
            p.then(function() {
              // 有声播放成功
              setUI(true);
              state.playing = true;
              saveState();
            }).catch(function(err) {
              // 任何失败都走静音重试，不依赖具体错误类型
              audio.muted = true;
              audio.volume = 1.0;
              isMuted = true;
              unmutePending = true;
              updateMuteUI();

              var p2 = audio.play();
              if (p2 && p2.then) {
                p2.then(function() {
                  // 静音播放成功
                  setUI(true);
                  state.playing = true;
                  saveState();
                  setupUnmuteListeners();
                }).catch(function() {
                  // 连静音都不行，等用户交互
                  setUI(false);
                  state.playing = false;
                  saveState();
                  setupFallbackListeners();
                });
              }
            });
          }
        }

        // 用户首次交互 → 取消静音
        function setupUnmuteListeners() {
          function onInteract() {
            tryUnmute();
            document.removeEventListener('click', onInteract);
            document.removeEventListener('keydown', onInteract);
            document.removeEventListener('touchstart', onInteract);
          }
          document.addEventListener('click', onInteract);
          document.addEventListener('keydown', onInteract);
          document.addEventListener('touchstart', onInteract);
        }

        // 连静音播放都被阻止 → 等交互后从零开始
        function setupFallbackListeners() {
          function resume() {
            audio.muted = false;
            audio.volume = state.volume;
            volInput.value = audio.volume * 100;
            isMuted = false;
            unmutePending = false;
            updateMuteUI();
            audio.play().then(function() {
              setUI(true);
              state.playing = true;
              saveState();
            }).catch(function() {});
            document.removeEventListener('click', resume);
            document.removeEventListener('keydown', resume);
            document.removeEventListener('touchstart', resume);
            // 同时清理 unmute 监听
            tryUnmute();
          }
          document.addEventListener('click', resume);
          document.addEventListener('keydown', resume);
          document.addEventListener('touchstart', resume);
        }

        // ---- 音频事件 ----
        audio.addEventListener('timeupdate', function() {
          if (audio.duration && isFinite(audio.duration)) {
            progressEl.value = (audio.currentTime / audio.duration) * 100;
          }
          saveState(); // 已节流
        });

        audio.addEventListener('ended', function() {
          currentIndex = (currentIndex + 1) % playlist.length;
          loadTrack(currentIndex, 0);
          tryPlay();
        });

        audio.addEventListener('pause', function() {
          setUI(false);
          saveState();
        });

        audio.addEventListener('play', function() {
          setUI(true);
        });

        // ---- 播放器控制 ----
        // Popup toggle
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          popup.classList.toggle('open');
        });
        document.addEventListener('click', function(e) {
          if (!popup.contains(e.target) && e.target !== btn) {
            popup.classList.remove('open');
          }
        });

        // Play/Pause
        playBtn.addEventListener('click', function() {
          if (!audio.src) loadTrack(currentIndex, 0);
          if (audio.paused) {
            // 如果处于静音状态，播放时尝试恢复音量
            if (isMuted) tryUnmute();
            tryPlay();
          } else {
            audio.pause();
            setUI(false);
            state.playing = false;
            saveState();
          }
        });

        // Prev
        popup.querySelector('#pp-prev').addEventListener('click', function() {
          currentIndex = (currentIndex - 1 + playlist.length) % playlist.length;
          loadTrack(currentIndex, 0);
          tryPlay();
        });

        // Next
        popup.querySelector('#pp-next').addEventListener('click', function() {
          currentIndex = (currentIndex + 1) % playlist.length;
          loadTrack(currentIndex, 0);
          tryPlay();
        });

        // Progress seek
        progressEl.addEventListener('input', function() {
          if (audio.duration && isFinite(audio.duration)) {
            audio.currentTime = (progressEl.value / 100) * audio.duration;
          }
        });

        // Volume
        volInput.addEventListener('input', function() {
          var v = volInput.value / 100;
          state.volume = v;
          if (isMuted) {
            // 用户主动调音量 → 顺势取消静音
            isMuted = false;
            unmutePending = false;
            audio.muted = false;
            updateMuteUI();
          }
          audio.volume = v;
          saveState();
        });

        // 页面离开前最后保存
        window.addEventListener('beforeunload', function() {
          try {
            localStorage.setItem(STORE_KEY, JSON.stringify({
              index: currentIndex,
              time: audio.currentTime || 0,
              playing: !audio.paused,
              volume: state.volume
            }));
          } catch(e) {}
        });

        // 页面隐藏时也保存（移动端切换 tab / 锁屏）
        document.addEventListener('visibilitychange', function() {
          if (document.hidden) {
            try {
              localStorage.setItem(STORE_KEY, JSON.stringify({
                index: currentIndex,
                time: audio.currentTime || 0,
                playing: !audio.paused,
                volume: state.volume
              }));
            } catch(e) {}
          }
        });

        // ---- 启动 ----
        loadTrack(currentIndex, state.time);
        if (state.playing) {
          tryPlay();
        } else {
          setUI(false);
        }
      })();
  </script>
)}

<style is:global>
  #bg-player-btn {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    cursor: pointer;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    transition: all 0.2s;
    color: var(--text);
    user-select: none;
  }
  #bg-player-btn:hover {
    background: rgba(255,255,255,0.8);
    border-color: var(--text);
  }
  #bg-player-btn.playing {
    animation: bgp-spin 3s linear infinite;
    border-color: var(--text);
  }
  @keyframes bgp-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  #bg-player-popup {
    position: fixed;
    bottom: 5.5rem;
    right: 1.5rem;
    width: 260px;
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
    z-index: 999;
    font-size: 0.85rem;
    color: var(--text);
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    display: none;
    flex-direction: column;
    gap: 0.6rem;
  }
  #bg-player-popup.open { display: flex; }
  #bg-player-popup .pp-title {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #bg-player-popup .pp-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  #bg-player-popup .pp-controls button {
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.25rem 0.6rem;
    cursor: pointer;
    font-size: 0.9rem;
    color: var(--text);
    transition: all 0.15s;
    line-height: 1;
  }
  #bg-player-popup .pp-controls button:hover {
    background: var(--hover);
    border-color: var(--text);
  }
  #bg-player-popup .pp-progress {
    width: 100%;
    height: 4px;
    border-radius: 2px;
    background: var(--border);
    cursor: pointer;
    appearance: none;
    outline: none;
  }
  #bg-player-popup .pp-progress::-webkit-slider-thumb {
    appearance: none;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--text);
    cursor: pointer;
  }
  #bg-player-popup .pp-vol {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--muted);
  }
  #bg-player-popup .pp-vol input {
    flex: 1;
    height: 3px;
    appearance: none;
    background: var(--border);
    border-radius: 2px;
    outline: none;
  }
  #bg-player-popup .pp-vol input::-webkit-slider-thumb {
    appearance: none;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--text);
    cursor: pointer;
  }
</style>
