---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import AudioPlayer from "../components/AudioPlayer.astro";
import { readdirSync } from "node:fs";
import { join } from "node:path";

export interface Props {
  title: string;
  description?: string;
}

const galleryDir = join(process.cwd(), "public", "gallery");
let galleryImages: string[] = [];
try {
  galleryImages = readdirSync(galleryDir)
    .filter((f) => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(f))
    .map((f) => `/gallery/${encodeURIComponent(f)}`);
} catch {}

const hasGallery = galleryImages.length > 0;
const defaultBg = hasGallery
  ? galleryImages[Math.floor(Math.random() * galleryImages.length)]
  : "";
const galleryJson = JSON.stringify(galleryImages);
---

<!DOCTYPE html>
<html
  lang="zh-CN"
  style={hasGallery ? `background-image:url(${defaultBg});background-size:cover;background-position:center;background-attachment:fixed;background-repeat:no-repeat;` : ""}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title} — treefish</title>
    <meta name="description" content={Astro.props.description || "个人博客"} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <style is:inline>
      /* 关键样式内联，100% 可靠 */
      html { background-color: transparent !important; }
      body { background: transparent !important; }
      .site-header, main, .site-footer {
        background: rgba(255,255,255,0.45) !important;
        backdrop-filter: blur(8px) !important;
        -webkit-backdrop-filter: blur(8px) !important;
        border-radius: 10px !important;
      }
      main { padding: 1.75rem 1.5rem; }
      .site-header { padding: 0.85rem 1.25rem; margin-bottom: 1rem; }
      .site-footer { padding: 0.85rem 1.25rem; margin-top: 1rem; border-top: none !important; }
    </style>
  </head>
  <body data-gallery={galleryJson}>
    <Sidebar />
    <AudioPlayer />
    <div id="page-wrap">
    <header class="site-header">
      <a class="logo" href="/">treefish</a>
      <nav>
        <a href="/">文章</a>
        <a href="/categories">分类</a>
        <a href="/tags">标签</a>
        <a href="/timeline">时间线</a>
        <a href="/search">搜索</a>
        <a href="/about">关于</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      &copy; {new Date().getFullYear()} treefish.top
    </footer>
    </div>

    <script is:inline>
      (function(){
        var raw = document.body.getAttribute('data-gallery');
        if (!raw || raw === '[]') return;
        var imgs = JSON.parse(raw);
        var pick = imgs[Math.floor(Math.random() * imgs.length)];
        document.documentElement.style.backgroundImage = 'url(' + pick + ')';
      })();
    </script>
  </body>
</html>
