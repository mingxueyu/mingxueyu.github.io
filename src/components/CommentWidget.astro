---
// CommentWidget.astro — 评论区（客户端渲染）
export interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<section id="comments" data-post-slug={postSlug}>
  <p style="color: var(--color-muted);">评论加载中…</p>
</section>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const container = document.getElementById("comments")!;
  const postSlug = container.dataset.postSlug!;

  async function loadComments() {
    const { data: comments, error } = await supabase
      .from("comments")
      .select("id, body, created_at, user_id")
      .eq("post_slug", postSlug)
      .order("created_at", { ascending: true });

    return { comments: comments || [], error };
  }

  async function getDisplayName(userId: string) {
    // 用 email 的 @ 前面部分作为显示名
    const { data } = await supabase.auth.getUser();
    if (data.user?.id === userId) {
      return data.user.email?.split("@")[0] || "匿名";
    }
    return "用户" + userId.slice(0, 6);
  }

  async function render() {
    const { data: userData } = await supabase.auth.getUser();
    const user = userData.user;
    const { comments } = await loadComments();

    // 获取所有评论者的显示名
    const userIds = [...new Set(comments.map((c) => c.user_id))];
    const nameMap: Record<string, string> = {};
    for (const uid of userIds) {
      nameMap[uid] = await getDisplayName(uid);
    }

    const commentsHtml =
      comments.length === 0
        ? `<p style="color: var(--color-muted);">暂无评论，来说两句吧</p>`
        : comments
            .map(
              (c) => `
            <div style="padding: 1rem 0; border-bottom: 1px solid var(--color-border);">
              <div style="font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.35rem;">
                <strong>${nameMap[c.user_id] || "用户"}</strong>
                · ${new Date(c.created_at).toLocaleDateString("zh-CN", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                  hour: "2-digit",
                  minute: "2-digit",
                })}
              </div>
              <p style="margin: 0; white-space: pre-wrap;">${c.body}</p>
            </div>
          `
            )
            .join("");

    const formHtml = user
      ? `
        <form id="comment-form" style="margin-top: 1.5rem;">
          <textarea id="comment-body" rows="3" placeholder="写下你的想法…" required
                    style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: 8px; font-family: inherit; font-size: 0.95rem; resize: vertical;"></textarea>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-top: 0.5rem;">
            <button type="submit"
                    style="padding: 0.5rem 1.25rem; background: var(--color-accent); color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 0.95rem;">
              发表评论
            </button>
            <span style="font-size: 0.85rem; color: var(--color-muted);">已登录：${user.email}</span>
          </div>
          <p id="comment-msg" style="margin-top: 0.5rem; font-size: 0.9rem;"></p>
        </form>`
      : `
        <div style="margin-top: 1.5rem; padding: 1rem; background: var(--color-border); border-radius: 8px; text-align: center;">
          <a href="/about" style="color: var(--color-accent);">登录</a> 后发表评论
        </div>`;

    container.innerHTML = `
      <h2 style="margin-top: 3rem; margin-bottom: 1rem;">评论 (${comments.length})</h2>
      ${commentsHtml}
      ${formHtml}
    `;

    // 绑定表单事件
    const form = document.getElementById("comment-form");
    const msg = document.getElementById("comment-msg");
    if (form && msg) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const body = (document.getElementById("comment-body") as HTMLTextAreaElement).value.trim();
        if (!body) return;

        msg.textContent = "发表中…";
        const { error } = await supabase.from("comments").insert({
          post_slug: postSlug,
          user_id: user!.id,
          body,
        });

        if (error) {
          msg.innerHTML = `<span style="color: red;">发表失败：${error.message}</span>`;
        } else {
          // 刷新评论列表
          render();
        }
      });
    }
  }

  render();
</script>
