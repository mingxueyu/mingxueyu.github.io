---
import { getCollection } from "astro:content";
import TreeItem from "./TreeItem.astro";

// 构建分类树
interface Node {
  count: number;
  children: Map<string, Node>;
}
const root: Map<string, Node> = new Map();
const posts = await getCollection("blog");

for (const post of posts) {
  if (post.data.draft) continue;
  const cats = post.data.categories;
  if (cats.length === 0) continue;
  let cur = root;
  for (const cat of cats) {
    if (!cur.has(cat)) cur.set(cat, { count: 0, children: new Map() });
    cur.get(cat)!.count++;
    cur = cur.get(cat)!.children;
  }
}

// 将嵌套 Map 转为 TreeItem 可用的数组结构
function toArray(map: Map<string, Node>, prefix = ""): any[] {
  return [...map.entries()]
    .sort((a, b) => b[1].count - a[1].count)
    .map(([name, node]) => ({
      name,
      path: prefix ? `${prefix}/${name}` : name,
      count: node.count,
      children: toArray(node.children, prefix ? `${prefix}/${name}` : name),
    }));
}

const categories = toArray(root);
---

<aside id="sidebar">
  <div id="sidebar-inner">
    <div class="sidebar-head">
      <a href="/categories" class="sidebar-title">📂 分类</a>
    </div>
    <nav>
      {categories.length > 0 ? (
        <ul class="tree-root">
          {categories.map((cat) => <TreeItem {...cat} />)}
        </ul>
      ) : (
        <p class="tree-empty">暂无分类</p>
      )}
    </nav>
  </div>
</aside>

<style>
  #sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 230px;
    height: 100vh;
    border-right: 1px solid var(--border);
    background: rgba(255,255,255,0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow-y: auto;
    overflow-x: hidden;
    z-index: 10;
    padding: 1.5rem 1rem;
    font-size: 0.88rem;
  }

  .sidebar-head {
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    padding-left: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
  }

  .sidebar-title:hover { opacity: 0.6; }

  .tree-root {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tree-root > li {
    position: relative;
  }

  .tree-empty {
    color: var(--muted);
    padding: 0.25rem 0.5rem;
    font-size: 0.85rem;
  }

  /* 移动端 */
  @media (max-width: 860px) {
    #sidebar { display: none; }
  }
</style>
