---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import AudioPlayer from "../components/AudioPlayer.astro";
import { readdirSync } from "node:fs";
import { join } from "node:path";

export interface Props {
  title: string;
  description?: string;
}

const galleryDir = join(process.cwd(), "public", "gallery");
let galleryImages: string[] = [];
try {
  galleryImages = readdirSync(galleryDir)
    .filter((f) => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(f))
    .map((f) => `/gallery/${encodeURIComponent(f)}`);
} catch {}

const hasGallery = galleryImages.length > 0;
const defaultBg = hasGallery
  ? galleryImages[Math.floor(Math.random() * galleryImages.length)]
  : "";
const galleryJson = JSON.stringify(galleryImages);
---

<!DOCTYPE html>
<html
  lang="zh-CN"
  style={hasGallery ? `background-image:url(${defaultBg});background-size:cover;background-position:center;background-attachment:fixed;background-repeat:no-repeat;` : ""}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title} — treefish</title>
    <meta name="description" content={Astro.props.description || "个人博客"} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <style is:inline>
      /* 关键样式内联，100% 可靠 */
      html { background-color: transparent !important; }
      body { background: transparent !important; }
      .site-header, main, .site-footer {
        background: rgba(255,255,255,0.45) !important;
        backdrop-filter: blur(8px) !important;
        -webkit-backdrop-filter: blur(8px) !important;
        border-radius: 10px !important;
      }
      main { padding: 1.75rem 1.5rem; }
      .site-header { padding: 0.85rem 1.25rem; margin-bottom: 1rem; }
      .site-footer { padding: 0.85rem 1.25rem; margin-top: 1rem; border-top: none !important; }
    </style>
  </head>
  <body data-gallery={galleryJson}>
    <Sidebar />
    <AudioPlayer />
    <div id="page-wrap">
    <header class="site-header">
      <a class="logo" href="/">treefish</a>
      <nav>
        <a href="/">文章</a>
        <a href="/categories">分类</a>
        <a href="/tags">标签</a>
        <a href="/timeline">时间线</a>
        <a href="/search">搜索</a>
        <a href="/guestbook">留言板</a>
        <a href="/about">关于</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      &copy; {new Date().getFullYear()} treefish.top
    </footer>
    </div>

    <script is:inline>
      (function(){
        var raw = document.body.getAttribute('data-gallery');
        if (!raw || raw === '[]') return;
        var imgs = JSON.parse(raw);
        var pick = imgs[Math.floor(Math.random() * imgs.length)];
        document.documentElement.style.backgroundImage = 'url(' + pick + ')';
      })();
    </script>

    <!-- 极简客户端路由：只替换 <main> 内容，不销毁音频播放器 -->
    <script is:inline>
      (function() {
        if (!window.history || !window.history.pushState) return;

        function isInternal(href) {
          return href && href.startsWith('/') && !href.startsWith('//');
        }

        // 处理导航链接点击
        function handleClick(e) {
          var a = e.target.closest('a');
          if (!a) return;

          // 完整重载标记（搜索页等需要初始化 JS 的页面）
          if (a.hasAttribute('data-full-reload')) return;

          var href = a.getAttribute('href');
          if (!href || !isInternal(href)) return;

          // 不拦截修饰键点击
          if (e.ctrlKey || e.metaKey || e.shiftKey || e.altKey) return;
          // 不拦截新窗口打开
          if (a.target === '_blank') return;
          // 跳过 RSS 等
          if (/\.(xml|json|pdf)$/i.test(href)) return;

          e.preventDefault();
          navigate(href);
        }

        function navigate(url) {
          fetch(url).then(function(res) {
            if (!res.ok) throw new Error('HTTP ' + res.status);
            return res.text();
          }).then(function(html) {
            // 用 DOMParser 解析新页面
            var parser = new DOMParser();
            var doc = parser.parseFromString(html, 'text/html');

            // 更新标题
            var newTitle = doc.querySelector('title');
            if (newTitle) document.title = newTitle.textContent;

            // 更新 <main> 内容
            var newMain = doc.querySelector('main');
            var currentMain = document.querySelector('main');
            if (newMain && currentMain) {
              // 1. 提取新内容中的 <script> 和 <link>（innerHTML 不会执行它们）
              var incomingScripts = newMain.querySelectorAll('script');
              var incomingLinks = newMain.querySelectorAll('link');

              // 2. 先设置 innerHTML（脚本不会执行，这正是我们要的）
              currentMain.innerHTML = newMain.innerHTML;

              // 3. 移除 innerHTML 带入的"死"脚本元素
              var deadScripts = currentMain.querySelectorAll('script');
              for (var si = 0; si < deadScripts.length; si++) {
                deadScripts[si].parentNode.removeChild(deadScripts[si]);
              }

              // 4. 重新创建脚本元素使其执行
              for (var sj = 0; sj < incomingScripts.length; sj++) {
                var s = incomingScripts[sj];
                var script = document.createElement('script');
                for (var ak = 0; ak < s.attributes.length; ak++) {
                  var attr = s.attributes[ak];
                  if (attr.name === 'src' && s.getAttribute('type') === 'module') {
                    // 模块脚本加 cache-busting 确保重复访问时重新执行
                    var sep = attr.value.indexOf('?') > -1 ? '&' : '?';
                    script.setAttribute('src', attr.value + sep + '_spa=' + Date.now());
                  } else {
                    script.setAttribute(attr.name, attr.value);
                  }
                }
                script.textContent = s.textContent;
                currentMain.appendChild(script);
              }

              // 5. 重新创建 <link> 元素（如 Pagefind CSS）
              for (var lk = 0; lk < incomingLinks.length; lk++) {
                var l = incomingLinks[lk];
                var link = document.createElement('link');
                for (var al = 0; al < l.attributes.length; al++) {
                  var la = l.attributes[al];
                  link.setAttribute(la.name, la.value);
                }
                document.head.appendChild(link);
              }
            }

            // 更新 gallery data（用于背景图）
            var newBody = doc.querySelector('body');
            if (newBody) {
              var newGallery = newBody.getAttribute('data-gallery');
              if (newGallery) {
                document.body.setAttribute('data-gallery', newGallery);
              }
            }

            // 更新 URL
            history.pushState({}, '', url);
          }).catch(function() {
            // 出错则完整加载
            window.location.href = url;
          });
        }

        // 浏览器前进/后退 → 完整重载（简单可靠）
        window.addEventListener('popstate', function() {
          window.location.reload();
        });

        // 委托点击事件
        document.addEventListener('click', handleClick);
      })();
    </script>
  </body>
</html>
