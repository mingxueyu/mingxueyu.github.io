---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import AudioPlayer from "../components/AudioPlayer.astro";
import { readdirSync } from "node:fs";
import { join } from "node:path";

export interface Props {
  title: string;
  description?: string;
}

// 扫描 public/gallery/ 中的图片
const galleryDir = join(process.cwd(), "public", "gallery");
let galleryImages: string[] = [];
let galleryScript = "";
let galleryStyle = "";
try {
  galleryImages = readdirSync(galleryDir)
    .filter((f) => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(f))
    .map((f) => `/gallery/${f}`);

  if (galleryImages.length > 0) {
    const json = JSON.stringify(galleryImages);
    galleryScript = `(function(){const imgs=${json};const u='url('+imgs[Math.floor(Math.random()*imgs.length)]+')';document.documentElement.style.backgroundImage=u;document.documentElement.classList.add('has-gallery');})();`;
    galleryStyle = `html.has-gallery{background-size:cover;background-position:center;background-attachment:fixed;background-repeat:no-repeat}body{background:transparent}`;
  }
} catch {
  // 目录不存在或为空
}
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title} — treefish</title>
    <meta name="description" content={Astro.props.description || "个人博客"} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
  </head>
  <body>
    <Sidebar />
    <AudioPlayer />
    <div id="page-wrap">
    <header class="site-header">
      <a class="logo" href="/">treefish</a>
      <nav>
        <a href="/">文章</a>
        <a href="/categories">分类</a>
        <a href="/tags">标签</a>
        <a href="/timeline">时间线</a>
        <a href="/search">搜索</a>
        <a href="/about">关于</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      &copy; {new Date().getFullYear()} treefish.top
    </footer>
    </div>

    {galleryScript && (
      <div set:html={`<script>${galleryScript}</script><style>${galleryStyle}</style>`} style="display:none" />
    )}
  </body>
</html>
