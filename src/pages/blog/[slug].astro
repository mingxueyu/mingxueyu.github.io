---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommentWidget from "../../components/CommentWidget.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <header>
      <div class="meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString("zh-CN", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {
          post.data.updated && (
            <span>
              {" "}· 更新于{" "}
              <time datetime={post.data.updated.toISOString()}>
                {post.data.updated.toLocaleDateString("zh-CN")}
              </time>
            </span>
          )
        }
      </div>
      <h1>{post.data.title}</h1>
      {post.data.categories.length > 0 && (
        <div style="font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.5rem;">
          📁{" "}
          {post.data.categories.map((cat, i) => {
            const link = "/categories/" + post.data.categories.slice(0, i + 1).join("/");
            return (
              <>
                {i > 0 && " › "}
                <a href={link} style="color: var(--color-accent);">{cat}</a>
              </>
            );
          })}
        </div>
      )}
      {post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag) => (
            <a class="tag" href={`/tags/${tag}`}>#{tag}</a>
          ))}
        </div>
      )}
    </header>
    <Content />
  </article>

  <CommentWidget postSlug={post.id} />
</BaseLayout>
