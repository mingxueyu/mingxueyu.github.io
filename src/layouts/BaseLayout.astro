---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title} — treefish</title>
    <meta name="description" content={Astro.props.description || "个人博客"} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
  </head>
  <body>
    <header class="site-header">
      <a class="logo" href="/">treefish</a>
      <nav>
        <a href="/">文章</a>
        <a href="/categories">分类</a>
        <a href="/tags">标签</a>
        <a href="/search">搜索</a>
        <a href="/about">关于</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      &copy; {new Date().getFullYear()} treefish.top
    </footer>
  </body>
</html>
